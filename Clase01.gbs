#-------------------------------------------------------

program {
    /*
        PROPOSITO: 
        PRECONDICIONES:
    */
    
    /*
        Mover(Este)
        Mover(Este)
        Mover(Este)
        Mover(Norte)
    */
    
    Poner(Rojo) // Accion(Argumento)
    Poner(Azul) // Pone una bolita de color azul en la celda actual
    // Poner(Azul)
    Poner(Azul)
    Poner(Azul)
    
    Sacar(Rojo)

}

#-------------------------------------------------------

program {
    /*
        (Que hace el programa)
        PROPOSITO: Pone una bolita color Azul y una bolita color Rojo en la celda actual
        
        (RESTRICCIONES)
        (Todo lo que se debe cumplir al momento de ejecutar el programa, para cumplir el proposito)
        PRECONDICIONES: Ninguna
    */
    Poner(Verde)
    Sacar(Verde)
    Poner(Azul)
    Poner(Rojo)
}

#-------------------------------------------------------

program {
    /*
        (Que hace el programa)
        PROPOSITO: Saca una bolita de color Verde y pone una bolita color Azul y una bolita
            color Rojo en la celda actual
        
        (RESTRICCIONES)
        (Todo lo que se debe cumplir al momento de ejecutar el programa, para cumplir el proposito)
        PRECONDICIONES: Debe haber al menos una bolita de color Verde en la celda actual 
    */
    Sacar(Verde)
    Poner(Azul)
    Poner(Rojo)
}

#-------------------------------------------------------

program {
    /*
        (Que hace el programa)
        PROPOSITO: Saca una bolita de color Verde en la celda actual y pone una bolita color Azul
            y una bolita color Rojo en la celda lindante al Este
        
        (RESTRICCIONES)
        (Todo lo que se debe cumplir al momento de ejecutar el programa, para cumplir el proposito)
        PRECONDICIONES:
            *Debe haber al menos una bolita de color Verde en la celda actual
            *Debe haber al menos una celda disponible al Este
    */
    Sacar(Verde)
    Mover(Este)
    Poner(Azul)
    Poner(Rojo)
}

