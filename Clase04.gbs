/*
c)
Sacar_SemillasEnDiagonalAl_Y_(cantidadDeSemillas, primeraDirDiagonal,
segundaDirDiagonal)
Deja el cabezal en la celda inicial.
*/
procedure Sacar_SemillasEnDiagonalAl_Y_(cantidadDeSemillas, primeraDirDiagonal, segundaDirDiagonal){
    /*
    PROPOSITO: Saca **cantidadDeSemillas** semillas al **primeraDirDiagonal** y al **segundaDirDiagonal**
    PRECONDICIONES: Debe haber al menos **cantidadDeSemillas** semillas en la parcela al **primeraDirDiagonal** y al **segundaDirDiagonal** y existir esta parcela
    PARAMETROS:
        *cantidadDeSemillas: Numero - es la cantidad de semillas a sacar
        *primeraDirDiagonal: Dirección - es la primer direccion de la diagonal
        *segundaDirDiagonal: Dirección - es la segunda direccion de la diagonal
    */
    MoverEnDiagonal_Y_(primeraDirDiagonal,segundaDirDiagonal)
    Sacar_Semillas(cantidadDeSemillas)
    MoverEnDiagonal_Y_(opuesto(primeraDirDiagonal),opuesto(segundaDirDiagonal))
}

procedure MoverEnDiagonal_Y_(unaDirecion,otraDireccion){
    /*
    TODO
    */
    Mover(unaDirecion)
    Mover(otraDireccion)
}

