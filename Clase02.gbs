/*
    U#02 - PROCEDIMIENTOS
        # Por arriba ( Visto el martes virtual)
        # El bosque, parte 1
        # Reloj Analogico Simplificado

*/


program{
    /*
    PROPOSITO: Pone un cuadrado de bolitas de color Verde en un tablero de 3x3 celdas.
        Comenzando y terminando en el centro del tablero.
    PRECONDICIONES:
        * El tablero inicial debe tener 3x3 celdas
        * El cabezal inicia en el centro del tablero
    */

    IrAlInicioDeUnTableroDe3x3() // BIBLIOTECA
    PonerFilaVerde()
    IrAlInicioDeLaSiguienteFilaAlNorte()
    PonerFilaVerde()
    IrAlInicioDeLaSiguienteFilaAlNorte()
    PonerFilaVerde()
    
    // Ir al Centro del tablero
    Mover(Sur) Mover(Oeste)
}

procedure IrAlInicioDeUnTableroDe3x3(){
    /*
    PROPOSITO: Lleva el cabezal al inicio del tablero en
        las coordenadas (0,0) en un tablero de 3x3
    PRECONDICIONES:
        * El tablero inicial debe tener 3x3 celdas
        * El cabezal inicia en el centro del tablero
    */
    Mover(Sur)
    Mover(Oeste)
}

procedure PonerFilaVerde(){
    /*
    PROPOSITO: Pone una fila de una bolita Verde por cada celda
        en un tablero de 3x3. Comenzando al Oeste y dejando
        el cabezal al Este.
    PRECONDICIONES:
        *Debe haber al menos 3 lugares disponibles al Este
    */
    Poner(Verde)
    Mover(Este)
    Poner(Verde)
    Mover(Este)
    Poner(Verde)
}

procedure IrAlInicioDeLaSiguienteFilaAlNorte(){
    /*
    PROPOSITO: Lleva el cabezal a la primera celda
        de la siguiente fila al norte en un tablero de 3x3
    PRECONDICIONES:
        * Debe existir al menos una fila lindante al
            Norte de la celda actual
        * Deben existir al menos 3 celdas al Oeste
            de la celda actual
    */
    Mover(Norte)
    Mover(Oeste)
    Mover(Oeste)
}

