        # Reloj Analogico Simplificado
procedure DibujarRelojAnalógicoSimplificado(){
    /*
    PROPOSITO: Dibuja un reloj analogico simplificado en un tablero
        de 5x5 iniciando en el centro
    PRECONDICIONES:
        * Debe haber al menos 2 celdas disponibles hacia
            cada una de las direcciones
    */
    IrAlBorde(Norte)
    MarcarLas12EnElReloj()
    
    IrAlNro3DesdeElNro12() // (pensar encapsulamiento en MarcarLasXEnElReloj)
    /*
    IrAlBorde(Este)
    Mover(Sur) Mover(Sur)
    */
    
    MarcarLas3EnElReloj()
    IrAlNro6DesdeElNro3()
    
    MarcarLas6EnElReloj()
    IrAlNro9DesdeElNro6()

    MarcarLas9EnElReloj()
    
    IrAlCentroDelReloj()
}

procedure MarcarLas12EnElReloj() {
    /*
    PROPOSITO: Pone el Nro 12 en la celda actual
    PRECONDICIONES:
        *La celda debe estar vacia
    */
    MarcarLas6EnElReloj()
    MarcarLas6EnElReloj()
}

procedure IrAlNro3DesdeElNro12() {
    /*
    PROPOSITO: Lleva el cabezal de el Nro 12 a la celda donde estará Nro 3
    PRECONDICIONES:
        * Debe haber al menos 2 celdas al Este y dos al Sur
    */
    IrAlBorde(Este)
    Mover(Sur)
    Mover(Sur)
}



