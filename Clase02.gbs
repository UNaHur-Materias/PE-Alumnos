procedure PonerUnaSemilla(){
    /*
    PROPOSITO: Pone una semilla en la parcela actual
    PRECONDICIONES: Ninguna
    */
    Poner(Rojo)
}

procedure SacarUnaSemilla(){
    /*
    PROPOSITO: Saca una semilla en la parcela actual
    PRECONDICIONES:
        * Debe haber al menos una semilla en la parcela actual
    */
    Sacar(Rojo)
}

